#!/usr/bin/env sh
# axon - Universal CI/CD scaffold tool
# https://github.com/suphakin-th/axon

set -e

VERSION="1.0.0"
REPO="suphakin-th/axon"
BASE_URL="https://raw.githubusercontent.com/${REPO}/main"

COMMON_TEMPLATES="
Dockerfile
docker-compose.yml
docker-compose.dev.yml
docker-compose.test.yml
.env.example
.gitignore
"

GITHUB_TEMPLATES="
.github/workflows/ci.yml
.github/workflows/migrate.yml
"

GITLAB_TEMPLATES="
.gitlab-ci.yml
"

# -- helpers ------------------------------------------------------------------

# Pure: return the template file list for the given platform
resolve_template_files() {
    platform="$1"
    echo "$COMMON_TEMPLATES"
    case "$platform" in
        github) echo "$GITHUB_TEMPLATES" ;;
        gitlab) echo "$GITLAB_TEMPLATES" ;;
        both)   echo "$GITHUB_TEMPLATES$GITLAB_TEMPLATES" ;;
    esac
}

# Pure: download one file from the remote template repo into the working dir
fetch_template() {
    file="$1"
    parentDir=$(dirname "$file")
    [ "$parentDir" != "." ] && mkdir -p "$parentDir"

    if command -v curl > /dev/null 2>&1; then
        curl -fsSL "${BASE_URL}/${file}" -o "$file" 2>/dev/null
    elif command -v wget > /dev/null 2>&1; then
        wget -qO "$file" "${BASE_URL}/${file}" 2>/dev/null
    else
        echo "axon: curl or wget is required" >&2 && exit 1
    fi
}

# Pure: decide to skip or fetch one file; print the outcome
scaffold_file() {
    file="$1"
    canOverwrite="$2"

    [ -z "$file" ] && return 0

    if [ -f "$file" ] && [ "$canOverwrite" -eq 0 ]; then
        printf "  skip    %s (exists - use --force to overwrite)\n" "$file"
        return 0
    fi

    if fetch_template "$file"; then
        printf "  create  %s\n" "$file"
    else
        printf "  error   %s (download failed)\n" "$file" >&2
    fi
}

# Pure: encode a file to base64, compatible with GNU base64 (Linux) and BSD base64 (macOS)
portable_base64_encode() {
    file="$1"
    if base64 --help 2>&1 | grep -q -- "-w"; then
        base64 -w 0 "$file"
    else
        base64 "$file" | tr -d '\n'
    fi
}

# -- commands -----------------------------------------------------------------

cmd_init() {
    platform="both"
    canOverwrite=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --platform) platform="$2"; shift ;;
            --github)   platform="github" ;;
            --gitlab)   platform="gitlab" ;;
            --force)    canOverwrite=1 ;;
            *)
                echo "axon: unknown option: $1" >&2
                echo "Run 'axon help' for usage." >&2
                exit 1
                ;;
        esac
        shift
    done

    case "$platform" in
        github|gitlab|both) ;;
        *)
            echo "axon: invalid platform '$platform' (use: github, gitlab, both)" >&2
            exit 1
            ;;
    esac

    echo "Scaffolding axon CI/CD (platform: $platform) ..."
    echo ""

    for file in $(resolve_template_files "$platform"); do
        scaffold_file "$file" "$canOverwrite"
    done

    echo ""
    echo "Done. Next steps:"
    echo ""
    echo "  1. Edit Dockerfile for your language (see comments inside)"
    echo "  2. cp .env.example .env && edit .env with your local values"
    echo "  3. Set CI/CD secrets (see README: https://github.com/${REPO})"
    echo "  4. docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d"
}

cmd_encode() {
    file="${1:-.env}"
    [ ! -f "$file" ] && echo "axon: file not found: $file" >&2 && exit 1

    portable_base64_encode "$file"
    echo "" >&2
    echo "Paste the above as APP_ENV_B64 in your CI/CD secret for the target environment." >&2
}

cmd_decode() {
    input="$1"
    if [ -z "$input" ]; then
        base64 -d
    else
        echo "$input" | base64 -d
    fi
}

cmd_version() {
    echo "axon v${VERSION}"
}

cmd_help() {
    cat <<HELP
axon v${VERSION} - Universal CI/CD scaffold

Usage:
  axon <command> [options]

Commands:
  init      Scaffold CI/CD files into the current project
  encode    Encode a .env file to base64 for CI/CD secrets
  decode    Decode a base64 string back to readable .env content
  version   Show version number
  help      Show this help

Options for init:
  --platform <p>   github, gitlab, or both (default: both)
  --force          Overwrite existing files

Examples:
  axon init                       scaffold all CI/CD files into current dir
  axon init --platform github     GitHub Actions files only
  axon init --platform gitlab     GitLab CI files only
  axon init --force               overwrite existing files

  axon encode .env.uat            encode for UAT environment secret
  axon encode .env.prod           encode for PROD environment secret
  axon decode "\$APP_ENV_B64"      preview what a secret decodes to

Docs: https://github.com/${REPO}
HELP
}

# -- entry point --------------------------------------------------------------

main() {
    cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        init)                 cmd_init "$@" ;;
        encode)               cmd_encode "$@" ;;
        decode)               cmd_decode "$@" ;;
        version|--version|-v) cmd_version ;;
        help|--help|-h)       cmd_help ;;
        *)
            echo "axon: unknown command '$cmd'" >&2
            echo "" >&2
            cmd_help >&2
            exit 1
            ;;
    esac
}

main "$@"
