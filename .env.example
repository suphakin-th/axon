# .env.example
# Copy to .env for local development.
# Never commit .env - only this template is committed to the repo.
# All real values for UAT and PROD are stored in CI/CD secrets (never here).
# -------------------------------------------------------------------------

# -- App ------------------------------------------------------------------
APP_NAME=axon
APP_ENV=development       # development | staging | production
APP_PORT=3000             # Host port exposed by docker compose
HEALTH_PATH=/health       # GET endpoint that returns 200 when the app is ready

# -- Deployed image (written by CI at deploy time - do not set manually) --
# APP_IMAGE=ghcr.io/org/axon
# APP_VERSION=abc1234

# -- Database -------------------------------------------------------------
DB_HOST=db                # Service name in docker-compose, or real hostname for prod
DB_PORT=5432
DB_DATABASE=app_dev
DB_USERNAME=app
DB_PASSWORD=CHANGE_ME

# -- Cache and Queue (uncomment if used) ----------------------------------
# REDIS_URL=redis://redis:6379

# -- Application secrets --------------------------------------------------
APP_SECRET=CHANGE_ME      # Session secret, JWT secret, or HMAC signing key

# -- External services (add your own below) -------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# S3_BUCKET=
# S3_KEY=
# S3_SECRET=
# THIRD_PARTY_API_KEY=
# WEBHOOK_SECRET=
